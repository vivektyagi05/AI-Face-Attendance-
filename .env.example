# Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=replace_with_long_random_secret_min_32_chars
AI_SERVICE_API_KEY=replace_with_shared_secret_32_chars

# Frontend build arg - browser calls this URL (use localhost for docker on same machine)
VITE_API_URL=http://localhost:5000/api/v1

# Backend CORS - where the React app runs
ALLOWED_ORIGINS=http://localhost:3000
