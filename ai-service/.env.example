# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
AI_SERVICE_PORT=8000

# ── Security ──────────────────────────────────────────────────
AI_SERVICE_API_KEY=change_this_shared_secret_key

# ── Face Recognition Tuning ───────────────────────────────────
# HOG = CPU-friendly; CNN = GPU-accelerated (more accurate)
FACE_DETECTION_MODEL=hog
# Number of times to re-sample face when encoding (higher = slower but more accurate)
NUM_JITTERS=1
# Default cosine-distance threshold if not sent by caller
DEFAULT_THRESHOLD=0.55

# ── Upload paths (temp storage, cleaned after processing) ─────
UPLOAD_FOLDER=./uploads/temp
