# ── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/smart_attendance

# ── JWT ───────────────────────────────────────────
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── File Upload ───────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ── Phase 2: AI Face Recognition Service ──────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=change_this_shared_secret_key
AI_TIMEOUT_MS=60000
